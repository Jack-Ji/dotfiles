{
    "inlayHint.enable": true,
    "semanticTokens.enable": true,
    "languageserver": {
        "dart" : {
            "command": "dart",
            "args": ["language-server", "--client-id", "vim.coc", "--client-version", "1.2"],
            "filetypes": ["dart"]
        },
        "zls" : {
            "command": "zls",
            "filetypes": ["zig", "zon"]
        },
        "ols" : {
            "command": "ols",
            "filetypes": ["odin"]
        },
        "phpactor": {
            "command": "phpactor",
            "args": ["language-server"],
            "trace.server": "verbose",
            "filetypes": ["php"]
        },
        "go": {
            "command": "gopls",
            "rootPatterns": ["go.mod"],
            "trace.server": "verbose",
            "filetypes": ["go"]
        }
    }
}

